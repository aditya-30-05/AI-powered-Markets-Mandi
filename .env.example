# Supabase Configuration (Optional - for user authentication)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Hugging Face API (Optional - for advanced speech recognition)
VITE_HUGGINGFACE_API_KEY=your_huggingface_token

# AGMARKNET API (Optional - for real government data)
VITE_AGMARKNET_API_KEY=your_agmarknet_key

# Development settings
VITE_ENABLE_MOCK_DATA=true
VITE_LOG_LEVEL=debug
